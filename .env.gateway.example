# TikTokDownloader Gateway
PORT=7790
ENVIRONMENT=production
LOG_LEVEL=INFO

# Optional API key (header: X-API-Key)
TIKTOK_API_KEY=

# Cookies (recommended for Douyin; TikTok may work without)
DOUYIN_COOKIE=
TIKTOK_COOKIE=

# Proxies
PROXY=
PROXY_TIKTOK=

# Cache / session
TIKTOK_EXTRACT_CACHE_TTL_SECONDS=1800
SESSION_TTL_SECONDS=300
SLIDESHOW_MAX_CONCURRENT=1

# REDIS_URL is set automatically in docker-compose to redis://redis:6379/0
# For local run without docker:
# REDIS_URL=redis://127.0.0.1:6379/0
